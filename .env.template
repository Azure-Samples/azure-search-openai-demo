# ========================================
# Complete Foundry + Azure OpenAI Configuration
# ========================================
# This is a template. Copy to .env and fill in your values.
# Store sensitive values in Azure Key Vault in production.

# ===== Azure Subscription & Region =====
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_TENANT_ID=<your-tenant-id>
AZURE_RESOURCE_GROUP=rg-rag-prod
AZURE_LOCATION=eastus
AZURE_ENV_NAME=prod
AZURE_PRINCIPAL_ID=<your-principal-id>  # Service principal or user object ID

# ===== Azure OpenAI Service (Latest Models) =====
AZURE_OPENAI_SERVICE=<org>-openai-prod
AZURE_OPENAI_RESOURCE_GROUP=rg-openai-prod
AZURE_OPENAI_LOCATION=eastus
AZURE_OPENAI_ENDPOINT=https://<org>-openai-prod.openai.azure.com/
AZURE_OPENAI_KEY=<openai-service-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Chat Model: Latest gpt-4o (multimodal, latest capabilities)
AZURE_OPENAI_CHATGPT_MODEL=gpt-4o
AZURE_OPENAI_DEPLOYMENT_CHATGPT=gpt-4o
AZURE_OPENAI_MODEL_VERSION=2024-05-13

# Embedding Model: text-embedding-3-large (1536 dimensions, superior quality)
AZURE_OPENAI_EMB_MODEL_NAME=text-embedding-3-large
AZURE_OPENAI_DEPLOYMENT_EMB=text-embedding-3-large
AZURE_OPENAI_EMB_DIMENSIONS=1536

# Optional: Fallback/Alternative Models
# AZURE_OPENAI_CHATGPT_FALLBACK_MODEL=gpt-4-turbo
# AZURE_OPENAI_MINI_MODEL=gpt-4-mini
# AZURE_OPENAI_EMBEDDING_FALLBACK=text-embedding-3-small

# ===== Azure AI Search (Hybrid + Vector Search) =====
AZURE_SEARCH_SERVICE=<org>-search-prod
AZURE_SEARCH_RESOURCE_GROUP=rg-search-prod
AZURE_SEARCH_LOCATION=eastus
AZURE_SEARCH_ENDPOINT=https://<org>-search-prod.search.windows.net/
AZURE_SEARCH_KEY=<search-service-key>
AZURE_SEARCH_INDEX=gptkbindex
AZURE_SEARCH_SEMANTIC_CONFIGURATION=my-semantic-config

# Vector Search Configuration
AZURE_USE_VECTOR_SEARCH=true
AZURE_USE_TEXT_SEARCH=true
AZURE_VECTOR_SEARCH_DIMENSIONS=1536
AZURE_VECTOR_SEARCH_K=5  # Top-k results

# ===== Azure Blob Storage =====
AZURE_STORAGE_ACCOUNT=<org>storageacct
AZURE_STORAGE_RESOURCE_GROUP=rg-storage-prod
AZURE_STORAGE_ENDPOINT=https://<org>storageacct.blob.core.windows.net/
AZURE_STORAGE_KEY=<storage-account-key>
AZURE_STORAGE_CONTAINER=documents
AZURE_BLOB_CONTAINER_NAME=documents

# ===== Azure Document Intelligence =====
AZURE_DOCUMENTINTELLIGENCE_SERVICE=<org>-docint-prod
AZURE_DOCUMENTINTELLIGENCE_RESOURCE_GROUP=rg-docint-prod
AZURE_DOCUMENTINTELLIGENCE_LOCATION=eastus
AZURE_DOCUMENTINTELLIGENCE_ENDPOINT=https://<org>-docint-prod.cognitiveservices.azure.com/
AZURE_DOCUMENTINTELLIGENCE_KEY=<docint-key>
AZURE_DOCUMENTINTELLIGENCE_SKU=S0

# ===== Optional: Azure Computer Vision (Multimodal Support) =====
ENABLE_MULTIMODAL=true
AZURE_VISION_SERVICE=<org>-vision-prod
AZURE_VISION_RESOURCE_GROUP=rg-vision-prod
AZURE_VISION_LOCATION=eastus
AZURE_VISION_ENDPOINT=https://<org>-vision-prod.cognitiveservices.azure.com/
AZURE_VISION_KEY=<vision-key>

# ===== Optional: Azure Content Understanding =====
ENABLE_CONTENT_UNDERSTANDING=false
AZURE_CONTENT_UNDERSTANDING_SERVICE=<org>-content-understanding
AZURE_CONTENT_UNDERSTANDING_RESOURCE_GROUP=rg-cu-prod
AZURE_CONTENT_UNDERSTANDING_KEY=<cu-key>

# ===== Optional: Azure Speech Services =====
ENABLE_SPEECH_INPUT=false
ENABLE_SPEECH_OUTPUT_AZURE=false
AZURE_SPEECH_SERVICE=<org>-speech-prod
AZURE_SPEECH_SERVICE_LOCATION=eastus
AZURE_SPEECH_SERVICE_KEY=<speech-key>
AZURE_SPEECH_SERVICE_VOICE=en-US-AriaNeural

# ===== Optional: Azure Cosmos DB (Chat History) =====
ENABLE_CHAT_HISTORY_COSMOS=false
AZURE_COSMOSDB_ACCOUNT=<org>-cosmosdb-prod
AZURE_COSMOSDB_KEY=<cosmosdb-key>
AZURE_COSMOSDB_CONVERSATIONS_CONTAINER=conversations
AZURE_COSMOSDB_DATABASE=chathistory

# ===== Microsoft Foundry Integration =====
FOUNDRY_PROJECT_NAME=azure-rag-system
FOUNDRY_SUBSCRIPTION_ID=<same-as-AZURE_SUBSCRIPTION_ID>
FOUNDRY_LOCATION=eastus
FOUNDRY_API_KEY=<foundry-api-key>
FOUNDRY_API_ENDPOINT=https://api.foundry.microsoft.com/
FOUNDRY_WORKSPACE_ID=<workspace-id>
FOUNDRY_MODEL_ENDPOINT=<foundry-model-endpoint>

# ===== Agentic RAG / Query Rewriting =====
ENABLE_AGENTIC_KNOWLEDGEBASE=true
ENABLE_AGENTIC_RETRIEVAL=true
ENABLE_QUERY_REWRITING=true
ENABLE_STREAMING=true
ENABLE_ADVANCED_REASONING=true
DEFAULT_REASONING_EFFORT=medium  # Options: low, medium, high

# ===== Knowledge Base Configuration =====
KNOWLEDGEBASE_INDEX_NAME=gptkbindex-kb
KNOWLEDGEBASE_ENDPOINT=<knowledge-base-endpoint>
KNOWLEDGEBASE_API_KEY=<kb-api-key>

# Data Sources
ENABLE_SHAREPOINT_SOURCE=false
ENABLE_WEB_SOURCE=false
ENABLE_TEAMS_SOURCE=false

# ===== Authentication & Authorization =====
AZURE_CLIENT_ID=<app-registration-id>
AZURE_CLIENT_SECRET=<app-secret>  # ⚠️ Use Key Vault in production
AUTH_ENABLED=true
ENABLE_ENTRA_LOGIN=true
ENFORCE_ACCESS_CONTROL=true

# ===== Azure Key Vault (Secrets Management) =====
AZURE_KEYVAULT_NAME=<org>-kv-prod
AZURE_KEYVAULT_ENDPOINT=https://<org>-kv-prod.vault.azure.net/

# Key Vault secret references (recommended for production)
# AZURE_OPENAI_KEY_REF=kv://openai-key
# AZURE_SEARCH_KEY_REF=kv://search-key
# AZURE_STORAGE_KEY_REF=kv://storage-key

# ===== Application Insights & Monitoring =====
AZURE_APPINSIGHTS_ENABLED=true
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
AZURE_APPINSIGHTS_WORKSPACE_NAME=ws-rag-prod
AZURE_LOG_ANALYTICS_WORKSPACE_ID=<workspace-id>

# Performance & Debugging
ENABLE_PERFORMANCE_TRACING=true
ENABLE_OPENAI_INSTRUMENTATION=true
ENABLE_SEARCH_INSTRUMENTATION=true
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR

# ===== Deployment & Hosting =====
AZURE_REGISTRY_NAME=<org>acr
AZURE_REGISTRY_ENDPOINT=https://<org>acr.azurecr.io/
AZURE_REGISTRY_KEY=<registry-key>

# Container Apps Deployment
AZURE_CONTAINER_APP_NAME=rag-app
AZURE_CONTAINER_ENV_NAME=rag-app-env
AZURE_CONTAINER_CPU=2
AZURE_CONTAINER_MEMORY=4Gi
AZURE_CONTAINER_PORT=8000
ENABLE_INGRESS=true

# Infrastructure as Code
BICEP_TEMPLATE=infra/main.bicep
BICEP_PARAMS=infra/main.parameters.json
DEPLOY_ENVIRONMENT=production  # Options: dev, staging, production

# ===== Feature Flags =====
ENABLE_RAG_CHAT=true
ENABLE_CODE_INTERPRETER=false
ENABLE_FUNCTION_CALLING=true
ENABLE_IMAGE_SEARCH=true
ENABLE_CITATION_FORMATTING=true
ENABLE_THOUGHT_PROCESS_DISPLAY=true

# ===== Development Settings =====
DEV_MODE=false
LOCAL_DEV_SERVER=false
LOCALHOST_PORT=5000
DEBUG_LOGGING=false

# ===== Data Ingestion =====
USE_CLOUD_INGESTION=true  # Set to true for cloud-based ingestion via Azure Functions
ENABLE_LOCAL_INGESTION=true
INGEST_BATCH_SIZE=10
MAX_DOCUMENT_SIZE_MB=50

# ===== Performance Tuning =====
OPENAI_EMBEDDING_BATCH_SIZE=100
SEARCH_BATCH_SIZE=50
MAX_SEARCH_RESULTS=100

# Caching
ENABLE_EMBEDDING_CACHE=true
ENABLE_SEARCH_CACHE=true
CACHE_TTL_HOURS=24

# ===== URLs & Endpoints =====
APP_URL=https://rag-app.azurewebsites.net
API_BASE_URL=https://rag-app.azurewebsites.net/api

# ===== Notifications & Alerts =====
ENABLE_ERROR_ALERTS=true
ALERT_EMAIL=ops@organization.com

# ===== Version & Metadata =====
APP_VERSION=1.0.0
FOUNDRY_VERSION=latest
OPENAI_API_VERSION=2024-08-01-preview
